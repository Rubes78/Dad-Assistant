# Copy this to .env and fill in your values

# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude model (default: claude-sonnet-4-6) ───────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Optional: port (default: 3456) ────────────────────────────────────────────
# PORT=3456

# ── Optional: basic auth — if set, a login prompt protects the whole UI ───────
# AUTH_USER=admin
# AUTH_PASS=yourpassword

# ── Admin info (used in escalation messages and notifications) ────────────────
ADMIN_NAME=Daniel
# ADMIN_CONTACT=555-123-4567

# ── SSH host access (remove or leave blank to disable) ────────────────────────
# IMPORTANT: Use a dedicated low-privilege user, not root.
# See README for setup instructions.
SSH_HOST=host.docker.internal
SSH_USER=assistant
SSH_KEY_PATH=/app/ssh_key

# ── Apprise notifications (optional — sends push alerts to admin) ─────────────
# APPRISE_URL is the Apprise sidecar container URL
APPRISE_URL=http://apprise:8000
# APPRISE_URLS defines where to send notifications
# Examples: pover://user@token, tgram://bot_token/chat_id, discord://webhook_id/webhook_token
# See https://github.com/caronc/apprise/wiki for all supported services
APPRISE_URLS=

# ── Service API credentials ──────────────────────────────────────────────────
# NOTE: These credentials are ONLY used by the tool layer (tools.js).
# They are NEVER sent to Anthropic or exposed to Claude.

RADARR_URL=http://host.docker.internal:7878/api/v3
RADARR_API_KEY=

SONARR_URL=http://host.docker.internal:8989/api/v3
SONARR_API_KEY=

PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=

OVERSEERR_URL=http://host.docker.internal:5055/api/v1
OVERSEERR_API_KEY=

SABNZBD_URL=http://host.docker.internal:7777
SABNZBD_API_KEY=

MAINTAINERR_URL=http://host.docker.internal:6246/api

# qBittorrent uses username/password instead of an API key
QB_URL=http://host.docker.internal:8888
QB_USER=
QB_PASS=

# Glances system metrics (no auth required)
GLANCES_URL=http://host.docker.internal:61208

# ── Backup settings (optional) ────────────────────────────────────────────────
# Where config backups are stored on the host (via SSH)
# BACKUP_DIR=/opt/fatharr-backups
